# Copy this file to .env and fill in real values before running the server.

# PostgreSQL connection string.
# Local example:      postgresql://postgres:postgres@localhost:5432/arden_darpoh_land
# Hosted (Render/Neon/Supabase) example:
#   postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/arden_darpoh_land

# Port the API server listens on
PORT=4000

# Secret used to sign login tokens (JWT). Use a long random string in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string

# How long a login session stays valid
JWT_EXPIRES_IN=12h

# Comma-separated list of frontend origins allowed to call this API
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Cloudinary (cloud storage for uploaded land documents — PDFs, site plans, IDs).
# Sign up free at https://cloudinary.com, then copy these three values from
# your Dashboard's "Product Environment Credentials" section.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
